# ============================================
# Ringside Sports — Environment Variables
# ============================================
# Secrets stored in 1Password vault: ringsidesports-next
# ============================================

# ── Postgres ──────────────────────────────────
DATABASE_URL=postgresql://ringsidesports:changeme@localhost:5432/ringsidesports

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Medusa Admin ──────────────────────────────
MEDUSA_ADMIN_EMAIL=admin@ringsidesports.com.au
MEDUSA_ADMIN_PASSWORD=changeme

# ── Stripe ────────────────────────────────────
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── MeiliSearch ────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=changeme
MEILISEARCH_PUBLIC_KEY=changeme

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_...

# ── Supplier XML ──────────────────────────────
SUPPLIER_XML_URL=https://extensionsell.com/x/export3/eca6a9-2.xml

# ── Cloudflare ────────────────────────────────
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# R2_BUCKET=ringsidesports-images
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...

# ── Medusa Publishable Key ────────────────────
MEDUSA_PUBLISHABLE_KEY=pk_...

# ── Medusa Admin API Key ──────────────────────
MEDUSA_ADMIN_API_KEY=...

# ── Domains ───────────────────────────────────
NEXT_PUBLIC_MEDUSA_API_URL=https://api.ringsidesports.com.au
NEXT_PUBLIC_MEILISEARCH_HOST=https://search.ringsidesports.com.au
ADMIN_CORS=https://admin.ringsidesports.com.au
STORE_CORS=https://ringsidesports.com.au
