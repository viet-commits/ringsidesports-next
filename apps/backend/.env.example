# Backend environment variables
# Secrets stored in 1Password vault ringsidesports-next

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ringsidesports

# Redis
REDIS_URL=redis://localhost:6379

# Medusa
MEDUSA_ADMIN_EMAIL=admin@ringsidesports.com.au
MEDUSA_ADMIN_PASSWORD=

# Stripe (test keys for phase 0-4, live for phase 5+)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# MeiliSearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Email (Resend)
RESEND_API_KEY=

# Admin domain
ADMIN_CORS=https://admin.ringsidesports.com.au
STORE_CORS=https://ringsidesports.com.au
