# Sync environment variables

# Supplier
SUPPLIER_XML_URL=https://extensionsell.com/x/export3/eca6a9-2.xml

# Postgres (for identity map, image cache, and direct Medusa DB access)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ringsidesports

# Cloudflare R2
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ringsidesports-images
R2_PUBLIC_URL=https://images.ringsidesports.com.au

# Data directory
SYNC_DATA_DIR=/opt/ringsidesports/data
SYNC_LOG_DIR=/opt/ringsidesports/logs
